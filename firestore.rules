rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Global safety net: Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Connection test path
    match /test/connection {
      allow get: if true;
    }

    // Global helpers
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // User validation
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email']) &&
             data.uid is string && data.uid.size() <= 128 &&
             data.email is string && data.email.size() <= 256 &&
             (!('displayName' in data) || data.displayName == null || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!('theme' in data) || (data.theme in ['obsidian', 'emerald', 'sunset', 'arctic']));
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isEmailVerified() && isOwner(userId) && isValidId(userId) &&
                    isValidUser(incoming()) && 
                    incoming().uid == request.auth.uid &&
                    incoming().createdAt == request.time &&
                    incoming().updatedAt == request.time;
      allow update: if isEmailVerified() && isOwner(userId) && isValidId(userId) &&
                    isValidUser(incoming()) && 
                    incoming().uid == existing().uid && 
                    incoming().email == existing().email &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().updatedAt == request.time &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['theme', 'displayName', 'updatedAt']);
      
      match /messages/{messageId} {
        allow read, write: if isOwner(userId);
      }
    }
  }
}
